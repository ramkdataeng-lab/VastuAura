platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "AuthKey.p8"
    )

    # Find the workspace file (handles name mismatches)
    workspace = Dir.glob("*.xcworkspace").first

    # Build the app with raw logs enabled to catch the specific error
    build_app(
      scheme: "App",
      workspace: workspace,
      export_method: "app-store",
      disable_xcpretty: true, # Show raw logs to find the real error
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Automatic -allowProvisioningUpdates -authenticationKeyPath #{Dir.pwd}/AuthKey.p8 -authenticationKeyID #{ENV['APP_STORE_CONNECT_KEY_ID']} -authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_ISSUER_ID']}"
    )

    # Upload to TestFlight
    upload_to_testflight(api_key: api_key)
  end
end
