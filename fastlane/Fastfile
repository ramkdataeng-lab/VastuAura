platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do |options|
    # App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "AuthKey.p8"
    )

    # Use workspace from options or default to App.xcworkspace
    target_workspace = options[:workspace] || "App.xcworkspace"

    # Build the app specifically for Capacitor App scheme
    build_app(
      scheme: "App",
      workspace: target_workspace,
      export_method: "app-store",
      api_key: api_key, # Pass authentication key directly to gym
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Automatic -allowProvisioningUpdates"
    )

    # Upload to TestFlight
    upload_to_testflight(api_key: api_key)
  end
end
